# ============================================
# Condo Vote - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite valores reais ou secrets
# ============================================

# ------------------------------
# Supabase
# ------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NOTA: não existe SUPABASE_JWT_SECRET aqui — validação do JWT é feita
# via JWKS (chaves públicas assimétricas). Spring busca as chaves em:
# ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Ver docs/architecture.md §1 "Por que JWKS em vez de HS256".

# ------------------------------
# Banco de Dados
# ------------------------------
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ------------------------------
# Redis
# ------------------------------
# Local:  redis://localhost:6379  (docker run -d --name redis-local -p 6379:6379 redis:7-alpine)
# Prod:   rediss://:password@your-db.upstash.io:6380  (Upstash → Connect → Redis CLI URL)
REDIS_URL=redis://localhost:6379

# ------------------------------
# E-mail
# Modo SMTP (padrão dev): usa Inbucket do Supabase (porta 54325, UI em http://localhost:54324)
# Modo Resend (teste local/prod): defina EMAIL_PROVIDER=resend e RESEND_API_KEY abaixo.
#   O docker-compose.yml já traz EMAIL_PROVIDER=resend — para voltar ao SMTP, edite o compose.
# ------------------------------
MAIL_HOST=127.0.0.1
MAIL_PORT=54325
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
EMAIL_PROVIDER=smtp
EMAIL_FROM=dev@condovote.local
EMAIL_ACCEPT_BASE_URL=http://localhost:4200

# Chave Resend para testes locais e produção (https://resend.com/api-keys).
# Necessária quando EMAIL_PROVIDER=resend (modo atual do docker-compose.yml).
# Em produção: configure como secret no Coolify/CI. Nunca commite o valor real.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------
# Invitation
# ------------------------------
INVITATION_TOKEN_TTL_HOURS=24

# ------------------------------
# Criptografia (CPF)
# ------------------------------
# Gere com: openssl rand -base64 32
# Armazene em cofre pessoal (1Password/Bitwarden) — única chave capaz de descriptografar CPFs
CPF_ENCRYPTION_KEY=your-32-byte-base64-key

# ------------------------------
# CORS
# ------------------------------
# Local: http://localhost:4200
# Prod:  https://app.condovote.com.br
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ------------------------------
# Aplicação
# ------------------------------
APP_ENV=local
SERVER_PORT=8080

# ============================================
# Frontend (Angular — prefixo NG_APP_*)
# ============================================
# Injetadas no build do Angular via Cloudflare Pages env vars (prod)
# ou file-replacements local

NG_APP_SUPABASE_URL=https://your-project.supabase.co
NG_APP_SUPABASE_ANON_KEY=your-anon-key
# Local: http://localhost:8080
# Prod:  https://api.condovote.com.br
NG_APP_API_URL=http://localhost:8080
