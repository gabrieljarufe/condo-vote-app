# Bruno collection — variáveis sensíveis
# Copie este arquivo para .env e preencha os valores
# .env é gitignored — nunca commite com valores reais

# Supabase anon key — local (Supabase CLI)
# Obtenha com: cd infra/supabase && supabase status --output json | jq -r '.ANON_KEY'
SUPABASE_ANON_KEY_LOCAL=

# Supabase anon key — prod (Supabase Cloud)
# Obtenha em: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY_PROD=

# Preenchido automaticamente pelo script de auth/Get Access Token
ACCESS_TOKEN=
