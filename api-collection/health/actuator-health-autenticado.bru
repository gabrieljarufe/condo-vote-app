meta {
  name: Actuator Health (autenticado)
  type: http
  seq: 4
}

get {
  url: {{base_url}}/actuator/health
  body: none
  auth: basic
}

auth:basic {
  username: {{actuator_user}}
  password: {{actuator_password}}
}

assert {
  res.status: eq 200
  res.body.status: eq UP
  res.body.components.db: isDefined
  res.body.components.redis: isDefined
}
