meta {
  name: Actuator Info
  type: http
  seq: 4
}

get {
  url: {{base_url}}/actuator/info
  body: none
  auth: none
}

script:pre-request {
  const user = bru.getVar("actuator_user");
  const pass = bru.getVar("actuator_password");
  req.setHeader("Authorization", "Basic " + btoa(user + ":" + pass));
}

assert {
  res.status: eq 200
  res.body.git: isDefined
  res.body.build: isDefined
}
