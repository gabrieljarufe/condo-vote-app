meta {
  name: Actuator Readiness
  type: http
  seq: 3
}

get {
  url: {{base_url}}/actuator/health/readiness
  body: none
  auth: none
}

script:pre-request {
  const user = bru.getVar("actuator_user");
  const pass = bru.getVar("actuator_password");
  req.setHeader("Authorization", "Basic " + btoa(user + ":" + pass));
}

assert {
  res.status: eq 200
  res.body.status: eq UP
}
